{
  "name": "hasnrizvee/dep-reaper",
  "description": "DepReaper: The ultimate PHP static analysis tool to find and remove unused Composer dependencies. Optimize your vendor directory with the Dependency Analyzer.",
  "type": "library",
  "license": "MIT",
  "authors": [{ "name": "Hasan Rizvee", "email": "your@email.com" }],
  "keywords": ["composer", "unused", "dependency", "dead code", "cleanup", "audit"],
  "require": {
    "php": ">=8.1",
    "nikic/php-parser": "^5.0",
    "symfony/console": "^6.0|^7.0",
    "symfony/dependency-injection": "^6.0|^7.0",
    "phpstan/phpdoc-parser": "^1.0",
    "composer-unused/symbol-parser": "^0.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.0"
  },
  "autoload": {
    "psr-4": { "DepReaper\\Engine\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": { "DepReaper\\Engine\\Tests\\": "tests/" }
  },
  "bin": ["bin/dep-reaper"],
  "config": {
    "bin-dir": "bin",
    "sort-packages": true
  }
}
